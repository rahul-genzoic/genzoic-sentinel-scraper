{
  "name": "sentinel-scraper",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx cli.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "import": "tsx cli.ts import --dir ../data",
    "migrate": "prisma migrate dev",
    "scrape:amazon-india": "tsx cli.ts scrape --source amazon-india",
    "scrape:amazon-us": "tsx cli.ts scrape --source amazon-us",
    "scrape:all": "tsx cli.ts scrape --source all",
    "scrape:amazon": "tsx cli.ts scrape --source amazon-india && tsx cli.ts scrape --source amazon-us",
    "check": "tsx cli.ts check --dir ../data",
    "check:fix": "tsx cli.ts check --dir ../data --fix"
  },
  "bin": {
    "sentinel": "./cli.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "p-limit": "^6.1.0",
    "playwright": "^1.48.0",
    "slugify": "^1.6.6",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
